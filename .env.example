PORT=8800
MONGO_URI=mongodb://localhost:27017/plangenie
JWT_SECRET=change_this_to_a_long_random_string
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# OpenAI (used for AI suggestions)
# Get an API key from https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key

# Resend email configuration (used by /api/misc/request-demo)
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key
# Sender must be a verified domain or address in Resend
RESEND_FROM=Plan Genie <no-reply@plangenie.com>
# Recipient for demo requests
TO_EMAIL=chike@plangenie.com
