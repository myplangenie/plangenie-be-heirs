NODE_ENV=development
PORT=8000

# MongoDB
MONGO_URI=mongodb://localhost:27017/plangenie

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Plan Genie <no-reply@plangenie.com>
TO_EMAIL=chike@plangenie.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
APP_WEB_URL=http://localhost:3000

# Storage (Cloudflare R2 – S3 compatible)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_BUCKET=profile-pictures
R2_LOGOS_BUCKET=business-logos
R2_LOGOS_PUBLIC_BASE_URL=https://logos.plangenie.com

# AI
OPENAI_API_KEY=
RAG_ENABLE=true
# Optional: override trainer text path
# RAG_TRAINER_TEXT_PATH=./data/business_trainer.txt

# Optional web search
# SERPAPI_API_KEY=
# BING_SUBSCRIPTION_KEY=
